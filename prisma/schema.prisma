generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// AUTH & USUÁRIOS
// ============================================================

enum UserRole {
  ADMIN
  SUPERVISOR
  PERSONAL_SHOPPER
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  role      UserRole @default(PERSONAL_SHOPPER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Relacionamentos
  accounts         Account[]
  sessions         Session[]
  assignedCustomers Customer[]       @relation("AssignedShopper")
  assignedLeads    LeadAssignment[]
  tasks            Task[]            @relation("AssignedTasks")
  createdTasks     Task[]            @relation("CreatedTasks")
  notes            Note[]
  auditLogs        AuditLog[]
  conversations    Conversation[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// CLIENTES
// ============================================================

enum CustomerSegment {
  VIP
  ALTO_POTENCIAL
  RECORRENTE
  EM_RISCO
  INATIVO
  NOVO
  PRIMEIRA_COMPRA
}

enum CustomerSource {
  SHOPIFY
  MANUAL
  OMNISEND
  WHATSAPP
  INDICACAO
}

model Customer {
  id String @id @default(cuid())

  // Identificação
  shopifyId    String?  @unique
  omnisendId   String?  @unique
  email        String   @unique
  firstName    String
  lastName     String
  phone        String?
  cpf          String?

  // Endereço principal
  city     String?
  state    String?
  country  String?   @default("Brazil")
  zipCode  String?
  address  String?

  // Dados de negócio
  segment       CustomerSegment @default(NOVO)
  source        CustomerSource  @default(SHOPIFY)
  rfmScore      Int?
  rfmRecency    Int?
  rfmFrequency  Int?
  rfmMonetary   Int?
  rfmLabel      String?
  engagementScore Int?

  // Histórico Shopify
  totalSpent      Decimal?  @db.Decimal(10, 2)
  ordersCount     Int?      @default(0)
  averageOrderValue Decimal? @db.Decimal(10, 2)
  lastOrderAt     DateTime?
  firstOrderAt    DateTime?
  shopifyTags     String[]
  acceptsMarketing Boolean  @default(false)

  // Personal Shopper responsável
  assignedShopperId String?
  assignedShopper   User?   @relation("AssignedShopper", fields: [assignedShopperId], references: [id])

  // Controle
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Relacionamentos
  orders           Order[]
  abandonedCarts   AbandonedCart[]
  conversations    Conversation[]
  tasks            Task[]
  notes            Note[]
  tags             CustomerTag[]
  scores           CustomerScore[]
  aiRecommendations AiRecommendation[]
  pipelineCards    PipelineCard[]
  leadAssignments  LeadAssignment[]
  emailEngagements EmailEngagement[]
  whatsappMessages WhatsappMessage[]

  @@index([email])
  @@index([shopifyId])
  @@index([segment])
  @@index([rfmScore])
  @@index([assignedShopperId])
  @@map("customers")
}

model CustomerTag {
  id         String   @id @default(cuid())
  customerId String
  tag        String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, tag])
  @@map("customer_tags")
}

// ============================================================
// PEDIDOS
// ============================================================

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  REFUNDED
  CANCELLED
}

model Order {
  id String @id @default(cuid())

  shopifyId     String  @unique
  orderNumber   Int
  customerId    String
  email         String?

  // Financeiro
  totalPrice      Decimal @db.Decimal(10, 2)
  subtotalPrice   Decimal @db.Decimal(10, 2)
  totalDiscounts  Decimal @db.Decimal(10, 2) @default(0)
  totalTax        Decimal @db.Decimal(10, 2) @default(0)
  currency        String  @default("BRL")

  // Status
  financialStatus    OrderStatus @default(PENDING)
  fulfillmentStatus  String?

  // Entrega
  shippingCity    String?
  shippingState   String?
  shippingCountry String?
  shippingZip     String?

  // Cupom
  discountCodes Json?

  // Shopify tags e notas
  tags          String[]
  note          String?   @db.Text
  shopifyTags   String[]

  // Datas
  processedAt DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relacionamentos
  customer   Customer    @relation(fields: [customerId], references: [id])
  lineItems  LineItem[]

  @@index([customerId])
  @@index([shopifyId])
  @@index([financialStatus])
  @@index([createdAt])
  @@map("orders")
}

model LineItem {
  id String @id @default(cuid())

  orderId       String
  shopifyItemId String
  productId     String?
  variantId     String?

  title         String
  variantTitle  String?
  sku           String?
  quantity      Int
  price         Decimal @db.Decimal(10, 2)
  totalDiscount Decimal @db.Decimal(10, 2) @default(0)

  productImage  String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("line_items")
}

// ============================================================
// CARRINHO ABANDONADO
// ============================================================

model AbandonedCart {
  id String @id @default(cuid())

  shopifyCheckoutId String  @unique
  customerId        String?
  email             String?

  totalPrice  Decimal @db.Decimal(10, 2)
  currency    String  @default("BRL")

  checkoutUrl String?
  lineItems   Json

  recoveredAt  DateTime?
  contactedAt  DateTime?
  abandonedAt  DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([email])
  @@index([abandonedAt])
  @@map("abandoned_carts")
}

// ============================================================
// PRODUTOS (cache local para recomendações)
// ============================================================

model Product {
  id String @id @default(cuid())

  shopifyId   String  @unique
  title       String
  vendor      String?
  productType String?
  tags        String[]
  status      String  @default("active")

  handle      String?
  imageUrl    String?
  price       Decimal? @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recommendations AiRecommendation[]

  @@index([shopifyId])
  @@map("products")
}

// ============================================================
// CONVERSAS (timeline unificada)
// ============================================================

enum ConversationChannel {
  EMAIL
  WHATSAPP
  PHONE
  IN_PERSON
  NOTE
}

enum ConversationDirection {
  INBOUND
  OUTBOUND
}

model Conversation {
  id String @id @default(cuid())

  customerId String
  userId     String?
  channel    ConversationChannel
  direction  ConversationDirection @default(OUTBOUND)

  subject String?
  body    String  @db.Text
  snippet String?

  // Referências externas
  gmailMessageId   String?
  gmailThreadId    String?

  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  @@index([customerId])
  @@index([channel])
  @@index([createdAt])
  @@map("conversations")
}

// ============================================================
// WHATSAPP
// ============================================================

enum WhatsappStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

model WhatsappMessage {
  id String @id @default(cuid())

  customerId String
  direction  ConversationDirection
  from       String
  to         String
  body       String  @db.Text
  status     WhatsappStatus @default(QUEUED)

  // Meta referências
  waMessageId   String?  @unique
  waTemplateId  String?

  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  failedAt    DateTime?
  failReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([createdAt])
  @@map("whatsapp_messages")
}

// ============================================================
// EMAIL ENGAGEMENT (Omnisend)
// ============================================================

model EmailEngagement {
  id String @id @default(cuid())

  customerId String
  email      String

  campaignId   String?
  campaignName String?
  subject      String?

  sentAt    DateTime?
  openedAt  DateTime?
  clickedAt DateTime?
  bouncedAt DateTime?

  openCount  Int @default(0)
  clickCount Int @default(0)

  createdAt DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([customerId, campaignId])
  @@index([customerId])
  @@map("email_engagements")
}

// ============================================================
// TAREFAS
// ============================================================

enum TaskType {
  FOLLOW_UP
  LIGACAO
  WHATSAPP
  EMAIL
  REUNIAO
  LEMBRETE
  OUTRO
}

enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

enum TaskPriority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

model Task {
  id String @id @default(cuid())

  customerId String?
  assignedToId String
  createdById  String

  type        TaskType
  status      TaskStatus   @default(PENDENTE)
  priority    TaskPriority @default(MEDIA)
  title       String
  description String?      @db.Text

  dueAt       DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer   Customer? @relation(fields: [customerId], references: [id])
  assignedTo User      @relation("AssignedTasks", fields: [assignedToId], references: [id])
  createdBy  User      @relation("CreatedTasks", fields: [createdById], references: [id])

  @@index([customerId])
  @@index([assignedToId])
  @@index([status])
  @@index([dueAt])
  @@map("tasks")
}

// ============================================================
// NOTAS INTERNAS
// ============================================================

model Note {
  id String @id @default(cuid())

  customerId String
  userId     String
  content    String @db.Text
  pinned     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([customerId])
  @@map("notes")
}

// ============================================================
// PIPELINE (KANBAN)
// ============================================================

model Pipeline {
  id   String @id @default(cuid())
  name String
  description String?
  active Boolean @default(true)
  order  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stages PipelineStage[]

  @@map("pipelines")
}

model PipelineStage {
  id         String  @id @default(cuid())
  pipelineId String
  name       String
  color      String  @default("#6366f1")
  order      Int
  isWon      Boolean @default(false)
  isLost     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pipeline Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  cards    PipelineCard[]

  @@index([pipelineId])
  @@map("pipeline_stages")
}

model PipelineCard {
  id         String @id @default(cuid())
  stageId    String
  customerId String

  title       String
  description String? @db.Text
  value       Decimal? @db.Decimal(10, 2)
  order       Int      @default(0)

  wonAt  DateTime?
  lostAt DateTime?
  lostReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stage    PipelineStage @relation(fields: [stageId], references: [id])
  customer Customer      @relation(fields: [customerId], references: [id])

  @@index([stageId])
  @@index([customerId])
  @@map("pipeline_cards")
}

// ============================================================
// DISTRIBUIÇÃO DE LEADS
// ============================================================

enum AssignmentStatus {
  PENDENTE
  ACEITO
  RECUSADO
  EXPIRADO
}

model LeadAssignment {
  id         String @id @default(cuid())
  customerId String
  userId     String

  status   AssignmentStatus @default(PENDENTE)
  reason   String?
  aiScore  Int?
  aiReason String? @db.Text

  assignedAt  DateTime  @default(now())
  respondedAt DateTime?
  expiresAt   DateTime?

  customer Customer @relation(fields: [customerId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([customerId])
  @@index([userId])
  @@index([status])
  @@map("lead_assignments")
}

// ============================================================
// SCORES E IA
// ============================================================

model CustomerScore {
  id         String @id @default(cuid())
  customerId String

  scoreType  String  // rfm, engagement, churn_risk, purchase_intent
  score      Int
  label      String?
  metadata   Json?
  calculatedAt DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([scoreType])
  @@map("customer_scores")
}

model AiRecommendation {
  id         String  @id @default(cuid())
  customerId String
  productId  String?

  type     String  // product, action, insight
  title    String
  reason   String  @db.Text
  score    Float?
  metadata Json?

  shown    Boolean  @default(false)
  clicked  Boolean  @default(false)

  expiresAt DateTime?
  createdAt DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id])

  @@index([customerId])
  @@map("ai_recommendations")
}

// ============================================================
// INTEGRAÇÕES (controle de sync)
// ============================================================

enum IntegrationType {
  SHOPIFY
  OMNISEND
  GMAIL
  WHATSAPP
  META_ADS
  GA4
}

enum SyncStatus {
  IDLE
  RUNNING
  SUCCESS
  ERROR
}

model Integration {
  id   String          @id @default(cuid())
  type IntegrationType @unique

  status      SyncStatus @default(IDLE)
  lastSyncAt  DateTime?
  lastError   String?    @db.Text
  syncedCount Int        @default(0)
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("integrations")
}

// ============================================================
// PERFIS DE SEGMENTO (atualizado mensalmente via script)
// ============================================================

model SegmentProfile {
  id      String @id @default(cuid())
  segment String @unique

  topProducts      Json // string[] — top 20 produtos mais comprados no segmento
  nextBuyProducts  Json // { after: string, buyNext: string[] }[] — sequências de compra
  avgTicket        Float
  avgOrdersPerYear Float
  avgDaysBetween   Int
  totalCustomers   Int
  summary          String // texto gerado por SQL, sem IA

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("segment_profiles")
}

// ============================================================
// AUDITORIA
// ============================================================

model AuditLog {
  id     String @id @default(cuid())
  userId String?

  action     String
  resource   String
  resourceId String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}
